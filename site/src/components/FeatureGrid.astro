---
import type { Feature } from "../content/landing";

interface Props {
  title: string;
  features: Feature[];
}

const { title, features } = Astro.props;
---

<section class="features">
  <h2 class="section-title">{title}</h2>
  <div class="feature-grid">
    {features.map((feature) => (
      <article class="feature-card">
        <h3>{feature.title}</h3>
        <p>{feature.body}</p>
      </article>
    ))}
  </div>
</section>
