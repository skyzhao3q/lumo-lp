---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import { privacyContent } from "../content/privacy";
import { landingContent } from "../content/landing";
import { localizedPath } from "../content/locales";

const locale = "en";
const page = "privacy";
const content = privacyContent[locale];
const homeHref = localizedPath(locale, "home");
---

<BaseLayout locale={locale} page={page} title={content.metaTitle} description={content.metaDescription}>
  <nav class="nav">
    <div class="nav-inner">
      <a class="nav-brand" href={homeHref}>
        <img class="nav-icon" src="/images/app-icon.png" alt="Lumo" />
        Lumo
      </a>
    </div>
  </nav>

  <main>
    <div class="policy-page">
      <a class="policy-back" href={homeHref}>← {content.backHome}</a>
      <h1 class="policy-title">{content.title}</h1>
      <p class="policy-date">{content.effectiveDate}</p>
      <p class="policy-intro">{content.intro}</p>
      {content.sections.map((section) => (
        <section class="policy-section">
          <h2>{section.title}</h2>
          {section.body.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </section>
      ))}
    </div>
  </main>

  <Footer locale={locale} page={page} privacyLabel={landingContent[locale].navPrivacy} />
</BaseLayout>
